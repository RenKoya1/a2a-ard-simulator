{
  "name": "a2a-sim",
  "version": "0.1.0",
  "description": "A2A protocol multi-agent simulation with web UI",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "test:contracts": "hardhat test",
    "chain:compile": "hardhat compile",
    "ui:dev": "npm --prefix web run dev",
    "ui:build": "npm --prefix web run build",
    "ui:typecheck": "npm --prefix web run typecheck",
    "postinstall": "npm --prefix web install",
    "prestart": "[ -d web/out ] || npm run ui:build"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.14",
    "ethers": "^6.17.0",
    "express": "^5.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-toolbox-mocha-ethers": "^3.0.7",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "chai": "^5.3.3",
    "hardhat": "^3.9.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
