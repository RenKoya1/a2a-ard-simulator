{
  "name": "a2a-sim",
  "version": "0.1.0",
  "description": "A2A protocol multi-agent simulation with web UI",
  "private": true,
  "type": "module",
  "scripts": {
    "start": "tsx src/main.ts",
    "dev": "tsx watch src/main.ts",
    "typecheck": "tsc --noEmit",
    "test:contracts": "hardhat test",
    "chain:compile": "hardhat compile"
  },
  "dependencies": {
    "@a2a-js/sdk": "^0.3.14",
    "ethers": "^6.17.0",
    "express": "^5.1.0",
    "uuid": "^11.1.0"
  },
  "devDependencies": {
    "@nomicfoundation/hardhat-chai-matchers": "^2.1.2",
    "@nomicfoundation/hardhat-ethers": "^3.1.3",
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "chai": "^4.5.0",
    "hardhat": "^2.28.6",
    "tsx": "^4.19.0",
    "typescript": "^5.8.0"
  }
}
